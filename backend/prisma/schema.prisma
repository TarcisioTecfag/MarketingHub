generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuthState {
  id    String @id
  value String @db.Text
}

model Birthday {
  id          String   @id @default(uuid())
  name        String
  birthDate   String   // Format: YYYY-MM-DD
  sendTime    String   @default("08:00") // Format: HH:MM
  groupId     String
  message     String   @db.Text
  imageBase64 String?  @db.Text
  status      String   @default("pendente")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeasonalCampaign {
  id          String   @id @default(uuid())
  title       String
  type        String
  sendDate    String   // Format: YYYY-MM-DD
  sendTime    String   @default("08:00") // Format: HH:MM
  groupId     String
  message     String   @db.Text
  imageBase64 String?  @db.Text
  status      String   @default("pendente")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CatalogConfig {
  id                     String   @id @default("tecfag")
  semiImageBase64        String?  @db.Text
  semiImageName          String?
  semiPdfBase64          String?  @db.Text
  semiPdfName            String?
  industrialImageBase64  String?  @db.Text
  industrialImageName    String?
  industrialPdfBase64    String?  @db.Text
  industrialPdfName      String?
  updatedAt              DateTime @updatedAt
}

model Visitor {
  id          String   @id @default(uuid())
  sessionId   String   @unique
  ip          String?
  country     String?
  countryCode String?
  city        String?
  region      String?
  timezone    String?
  latitude    Float?
  longitude   Float?
  browser     String?
  os          String?
  device      String?   // "mobile" | "tablet" | "desktop"
  language    String?
  referrer    String?
  screenW     Int?
  screenH     Int?
  duration    Int?      // segundos na página (null = ainda online)
  catalogViewed String? // "semi" | "industrial" | null
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

